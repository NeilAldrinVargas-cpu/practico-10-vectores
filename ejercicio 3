#include <iostream>

using namespace std;

// 1. FUNCIÓN PARA PEDIR LOS DATOS
void ingresarDatos(double vector[], int &n) {
    cout << "¿Cuántos números deseas ingresar? ";
    cin >> n;

    cout << "\nIntroduce los " << n << " números:" << endl;
    for (int i = 0; i < n; i++) {
        cout << "Número " << (i + 1) << ": ";
        cin >> vector[i];
    }
}

// 2. FUNCIÓN PARA CALCULAR EL PROMEDIO
double calcularPromedio(double vector[], int n) {
    double suma = 0; // Usamos un acumulador que empieza en cero

    // El ciclo for recorre todo el vector sumando cada casilla
    for (int i = 0; i < n; i++) {
        suma = suma + vector[i];
    }

    // Al final, dividimos la suma total entre la cantidad de números (n)
    double promedio = suma / n;

    return promedio; // Devolvemos el promedio calculado
}

// 3. FUNCIÓN PARA MOSTRAR EL RESULTADO
void mostrarResultado(double elPromedio) {
    cout << "\nEl promedio de los valores del vector es: " << elPromedio << endl;
}

// 4. FUNCIÓN PRINCIPAL
int main() {
    int n = 0;
    double miVector[100];

    // El int main sigue la misma estructura impecable:
    ingresarDatos(miVector, n);

    double elPromedio = calcularPromedio(miVector, n);

    mostrarResultado(elPromedio);

    return 0;
}
