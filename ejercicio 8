#include <iostream>
#include <cmath> // Necesaria para usar abs() (valor absoluto)

using namespace std;

// 1. FUNCIÓN PARA PEDIR LOS DATOS
void ingresarDatos(double vector[], int &n) {
    cout << "¿Cuántos números reales tendrá el vector A? ";
    cin >> n;

    // Validación: Se necesitan al menos 2 números para tener una pareja consecutiva
    while (n < 2) {
        cout << "[Error] El vector debe tener al menos 2 elementos. Intenta de nuevo: ";
        cin >> n;
    }

    cout << "Introduce los " << n << " números reales:" << endl;
    for (int i = 0; i < n; i++) {
        cout << "A[" << i << "]: ";
        cin >> vector[i];
    }
}

// 2. FUNCIÓN PARA ENCONTRAR LA DIFERENCIA MÁS GRANDE CONSECUTIVA
double calcularMaximaDiferencia(double vector[], int n) {
    // Calculamos la primera diferencia entre la casilla 0 y la casilla 1
    double maxDiferencia = abs(vector[0] - vector[1]);

    // Recorremos el vector calculando las diferencias de las siguientes parejas
    // El límite es (n - 1) para que 'i + 1' nunca se salga del vector
    for (int i = 1; i < n - 1; i++) {
        double diferenciaActual = abs(vector[i] - vector[i + 1]);
        
        // Si la diferencia de la pareja actual es mayor que nuestra máxima guardada, la actualizamos
        if (diferenciaActual > maxDiferencia) {
            maxDiferencia = diferenciaActual;
        }
    }
    return maxDiferencia;
}

// 3. FUNCIÓN PARA MOSTRAR EL REPORTE
void mostrarResultado(double mayorDiferencia) {
    cout << "\nLa diferencia más grande entre dos elementos consecutivos es: " << mayorDiferencia << endl;
}

// 4. FUNCIÓN PRINCIPAL
int main() {
    int n = 0;
    double vectorA[100];

    ingresarDatos(vectorA, n);
    
    double maximaDif = calcularMaximaDiferencia(vectorA, n);
    
    mostrarResultado(maximaDif);

    return 0;
}
