#include <iostream>

using namespace std;

// 1. FUNCIÓN PARA PEDIR LOS DATOS DE UN VECTOR
// Se usa un parámetro 'nombre' para reutilizar la misma función con el Vector A y B
void ingresarDatos(double vector[], int &tamano, char nombre) {
    cout << "¿Cuántos elementos tendrá el Vector " << nombre << "? ";
    cin >> tamano;

    // Validación: El vector debe tener al menos 1 elemento
    while (tamano <= 0 || tamano > 50) {
        cout << "[Error] El tamaño debe estar entre 1 y 50. Intenta de nuevo: ";
        cin >> tamano;
    }

    cout << "Introduce los " << tamano << " números para el Vector " << nombre << ":" << endl;
    for (int i = 0; i < tamano; i++) {
        cout << nombre << "[" << i << "]: ";
        cin >> vector[i];
    }
    cout << endl;
}

// 2. FUNCIÓN PARA CONCATENAR LOS DOS VECTORES
void concatenarVectores(double vectorA[], int n, double vectorB[], int m, double vectorC[]) {
    // Copiar los elementos del Vector A al Vector C
    for (int i = 0; i < n; i++) {
        vectorC[i] = vectorA[i];
    }

    // Copiar los elementos del Vector B al Vector C, justo después de los de A
    for (int j = 0; j < m; j++) {
        vectorC[n + j] = vectorB[j]; 
    }
}

// 3. FUNCIÓN PARA MOSTRAR EL VECTOR RESULTANTE
void mostrarResultado(double vectorC[], int tamanoTotal) {
    cout << "--- VECTOR CONCATENADO RESULTANTE ---" << endl;
    cout << "[ ";
    for (int i = 0; i < tamanoTotal; i++) {
        cout << vectorC[i];
        if (i < tamanoTotal - 1) {
            cout << ", "; // Agrega una coma estética entre elementos
        }
    }
    cout << " ]" << endl;
}

// 4. FUNCIÓN PRINCIPAL
int main() {
    // Declaración de variables
    double vectorA[50];
    double vectorB[50];
    double vectorC[100]; // Debe soportar la suma de ambos tamaños (50 + 50)
    
    int n = 0; // Tamaño del vector A
    int m = 0; // Tamaño del vector B

    // 1. Entrada de datos para ambos vectores
    ingresarDatos(vectorA, n, 'A');
    ingresarDatos(vectorB, m, 'B');
    
    // 2. Procesamiento (Concatenación)
    concatenarVectores(vectorA, n, vectorB, m, vectorC);
    
    // 3. Salida del reporte
    int tamanoTotal = n + m;
    mostrarResultado(vectorC, tamanoTotal);

    return 0;
}
